# 第一阶段：构建 React
FROM node:24-alpine as build

WORKDIR /app

# 复制 package.json 和 package-lock.json（只复制这两个文件，利用 Docker 缓存）
COPY frontend/package.json frontend/package-lock.json ./

# 安装依赖
RUN npm ci

# 复制前端代码（不包括 node_modules，因为有 .dockerignore）
COPY frontend/ .

# 打包 React
RUN npm run build

# 第二阶段：将打包结果复制到后端可访问的位置
FROM alpine:latest

WORKDIR /app/static/react_build

COPY --from=build /app/build/ .